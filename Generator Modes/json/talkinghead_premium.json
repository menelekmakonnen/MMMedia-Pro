{
  "schema_version": "1.0",
  "mode_id": "talkinghead_premium",
  "name": "Talking-Head — Premium Explainer",
  "family": "Talking-Head / Explainer",
  "derived_from": [
    "Cyber Security Regulation"
  ],
  "summary": "Highly produced single-presenter explainer: cross-dissolves between beats, graded look, on-screen caption capsules, zoom-blur emphasis transitions, and B-roll/graphic inserts over a music bed.",
  "best_for": "Educational/explainer videos, thought-leadership, branded long-form.",
  "canvas": {
    "resolution": "1440x1080 or 1920x1080",
    "aspect": "4:3 source / 16:9",
    "fps": 25
  },
  "pacing": {
    "cuts_per_min": [
      22,
      30
    ],
    "logic": "silence_removal + broll_coverage",
    "avg_clip_sec": [
      2.0,
      3.5
    ]
  },
  "source_layout": {
    "cameras": 1,
    "shot": "presenter medium",
    "broll": "frequent topic-driven inserts + motion graphics"
  },
  "reframe": {
    "method": "AE.ADBE Motion + AE.ADBE Geometry2 (Transform)",
    "scale_range_pct": [
      100,
      140
    ],
    "pattern": "punch-ins on emphasis; transform for push/zoom moves"
  },
  "effect_stack": [
    {
      "match_name": "AE.ADBE Motion",
      "role": "reframe"
    },
    {
      "match_name": "AE.ADBE Lumetri",
      "role": "color grade"
    },
    {
      "match_name": "AE.ADBE Capsule",
      "role": "caption capsule lower-third / keyword pills"
    },
    {
      "match_name": "AE.ADBE Geometry2",
      "role": "transform push/zoom"
    },
    {
      "match_name": "AE.ADBE Color Balance 2",
      "role": "secondary color"
    },
    {
      "match_name": "AE.ADBE Brightness & Contrast 2",
      "role": "pop"
    }
  ],
  "transitions": {
    "philosophy": "Choose the transition that fits the moment; never default to a hard cut.",
    "library": [
      "AE.ADBE Cross Dissolve New",
      "ZoomBlur (HitFilm) on emphasis",
      "CineStyle look transition",
      "seamless soft cut"
    ],
    "default": "AE.ADBE Cross Dissolve New",
    "notes": "Default to short cross-dissolves between talking beats; zoom-blur for energetic emphasis; cut straight to B-roll where it reads cleaner."
  },
  "color": {
    "approach": "polished branded grade",
    "lumetri": "contrast, color balance, brightness/contrast pop"
  },
  "audio": {
    "dialogue": "primary, processed",
    "music": "consistent bed (.m4a/.wav), ducked",
    "use_jl_cuts": true
  },
  "titles_graphics": {
    "captions": "capsule-styled keyword callouts",
    "lower_thirds": "branded",
    "graphics": "explainer motion graphics"
  },
  "toggles": [
    "zoom_blur_emphasis",
    "keyword_capsules",
    "broll_graphics",
    "branded_lowerthirds"
  ],
  "generator_rules": [
    "Cross-dissolve between presenter beats by default; reserve straight changes for B-roll entry.",
    "Surface keywords as capsule callouts synced to speech.",
    "Insert topic B-roll/graphics generously; grade everything to one look.",
    "Use zoom-blur transitions sparingly for emphasis."
  ]
}