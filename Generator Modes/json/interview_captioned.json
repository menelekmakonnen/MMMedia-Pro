{
  "schema_version": "1.0",
  "mode_id": "interview_captioned",
  "name": "Interview — Captioned (SRT)",
  "family": "Interview / Talking-Head",
  "derived_from": [
    "FREDRICK SRT FILE",
    "FREDRICK AMPOFO"
  ],
  "summary": "Clean interview with burned-in, styled captions driven from an SRT — built for silent-autoplay feeds while staying a polished talking-head edit.",
  "best_for": "Social-distributed interview clips, accessibility-first uploads.",
  "canvas": {
    "resolution": "1920x1080 (or 1080x1920 export)",
    "aspect": "16:9 / 9:16",
    "fps": 29.97
  },
  "pacing": {
    "cuts_per_min": [
      12,
      20
    ],
    "logic": "silence_removal",
    "avg_clip_sec": [
      3.0,
      6.0
    ]
  },
  "source_layout": {
    "cameras": 1,
    "shot": "medium-close",
    "broll": "optional"
  },
  "reframe": {
    "method": "AE.ADBE Motion",
    "scale_range_pct": [
      100,
      130
    ],
    "pattern": "Punch-ins on key phrases; keep subject clear of caption safe-area.",
    "purpose": "Add motion + emphasis around captions."
  },
  "effect_stack": [
    {
      "match_name": "AE.ADBE Motion",
      "role": "reframe"
    },
    {
      "role": "captions",
      "source": "SRT",
      "style": "bold, high-contrast, word-or-line sync, safe-margin"
    }
  ],
  "transitions": {
    "philosophy": "Choose the transition that fits the moment; never default to a hard cut.",
    "library": [
      "seamless soft cut",
      "reframe-covered cut",
      "short dissolve on topic change"
    ],
    "default": "seamless soft cut",
    "notes": "Keep transitions subtle so captions remain readable; no flashy wipes over text."
  },
  "color": {
    "approach": "natural grade",
    "lumetri": "light contrast"
  },
  "audio": {
    "dialogue": "primary, leveled",
    "music": "optional low bed",
    "use_jl_cuts": true
  },
  "titles_graphics": {
    "captions": "REQUIRED — SRT-driven, styled, animated in",
    "lower_thirds": "optional"
  },
  "toggles": [
    "word_level_highlight",
    "vertical_export",
    "emoji_keywords",
    "underscore_bed"
  ],
  "generator_rules": [
    "Ingest/auto-generate SRT; render styled captions in safe area.",
    "Sync caption appearance to speech; optionally highlight active word.",
    "Keep reframes from colliding with caption zone.",
    "Prefer subtle seams so text stays legible."
  ]
}