{
    "name": "mmmedia-pro",
    "private": true,
    "version": "1.0.0",
    "author": {
        "name": "Menelek Makonnen"
    },
    "description": "Professional Media Editor by ICUNI Labs",
    "main": "dist-electron/main.js",
    "scripts": {
        "dev": "cross-env ELECTRON_RUN_AS_NODE= vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "electron:dev": "cross-env ELECTRON_RUN_AS_NODE= vite",
        "electron:build": "npm run build && electron-builder",
        "build:electron": "tsc -p electron/tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:golden": "node scripts/test-golden-render.cjs"
    },
    "build": {
        "appId": "com.icunilabs.mmmediapro",
        "productName": "MMMedia Pro",
        "copyright": "Copyright © 2026 ICUNI Group - ICUNI Labs",
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "public/icon.ico"
        },
        "directories": {
            "output": "release/${version}"
        },
        "asarUnpack": [
            "node_modules/ffmpeg-static/**"
        ]
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "ffmpeg-static": "^5.3.0",
        "fluent-ffmpeg": "^2.1.3",
        "framer-motion": "^12.38.0",
        "lucide-react": "^0.462.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "seedrandom": "^3.0.5",
        "tailwind-merge": "^3.4.0",
        "uuid": "^11.0.5",
        "ws": "^8.20.0",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/node": "^22.10.5",
        "@types/react": "^19.0.6",
        "@types/react-dom": "^19.0.3",
        "@types/seedrandom": "^3.0.8",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react": "^4.3.4",
        "@webgpu/types": "^0.1.70",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.2.0",
        "cross-env": "^7.0.3",
        "electron": "^34.5.8",
        "electron-builder": "^24.13.3",
        "eslint": "^9.18.0",
        "eslint-plugin-react": "^7.37.3",
        "postcss": "^8.4.49",
        "sharp": "^0.34.5",
        "tailwindcss": "^3.4.18",
        "typescript": "~5.7.3",
        "vite": "^5.4.21",
        "vite-plugin-electron": "0.29.0",
        "vite-plugin-electron-renderer": "0.14.6",
        "vitest": "^4.1.8",
        "wait-on": "^8.0.2"
    }
}
